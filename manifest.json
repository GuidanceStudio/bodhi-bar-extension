{
  "manifest_version": 3,
  "name": "Bodhi Bar (bodhi-bar)",
  "version": "1.8",
  "author": "guidance.studio",
  "description": "Automatically removes new tabs from groups and provides a horizontal interface enhancement.",
  "permissions": [
    "tabs",
    "tabGroups",
    "scripting",
    "windows"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "constants.js",
        "messaging.js",
        "dom-helpers.js",
        "zoom.js",
        "page-shift.js",
        "popover.js",
        "drag-drop.js",
        "search.js",
        "render.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["site_overrides.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}
