{
  "manifest_version": 3,
  "name": "Bodhi Bar (bodhi-bar)",
  "version": "1.0",
  "author": "guidance.studio",
  "description": "Automatically removes new tabs from groups and provides a horizontal interface enhancement.",
  "permissions": [
    "tabs",
    "tabGroups",
    "windows",
    "storage",
    "downloads"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/leaf-16.png",
      "32": "assets/icons/leaf-32.png",
      "48": "assets/icons/leaf-48.png",
      "128": "assets/icons/leaf-128.png"
    }
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/constants.js",
        "src/content/messaging.js",
        "src/content/dom-helpers.js",
        "src/content/zoom.js",
        "src/content/popover.js",
        "src/content/drag-drop.js",
        "src/content/search.js",
        "src/content/render.js",
        "src/content/content.js"
      ],
      "css": ["src/content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "assets/icons/leaf-16.png",
    "32": "assets/icons/leaf-32.png",
    "48": "assets/icons/leaf-48.png",
    "128": "assets/icons/leaf-128.png"
  }
}
